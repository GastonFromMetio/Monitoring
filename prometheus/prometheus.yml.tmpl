global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - /etc/prometheus/alerts.yml

alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - alertmanager:9093

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets:
          - prometheus:9090
        labels:
          server_name: prometheus

  - job_name: monitoring-stack
    static_configs:
      - targets:
          - alertmanager:9093
        labels:
          server_name: alertmanager
      - targets:
          - grafana:3000
        labels:
          server_name: grafana
      - targets:
          - prometheus:9090
        labels:
          server_name: prometheus

  - job_name: node
    static_configs:
      - targets:
          - node-exporter:9100
        labels:
          server_name: dokploy
      - targets:
          - 168.222.244.56:9100
        labels:
          server_name: panthera

  - job_name: panthera
    scheme: https
    metrics_path: /metrics
    authorization:
      type: Bearer
      credentials: __PANTHERA_METRICS_AUTH_TOKEN__
    static_configs:
      - targets: ["panthera.metio-dev.fr"]
        labels:
          server_name: "panthera-prod"

  - job_name: http-health
    metrics_path: /probe
    scrape_interval: 60s
    scrape_timeout: 10s
    params:
      module: [http_2xx]
    static_configs:
      - targets:
          - https://apiaryhub.metio-dev.fr/health
        labels:
          server_name: apiaryhub
          service: apiaryhub
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: blackbox-exporter:9115
