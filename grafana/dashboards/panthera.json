{
  "uid": "panthera-metrics",
  "title": "Panthera /metrics",
  "tags": ["panthera", "metrics", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "camera_id",
        "label": "Camera",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(panthera_camera_has_error{job=\"panthera\"}, camera_id)",
          "refId": "PrometheusVariableQuery"
        },
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Metrics up",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 0, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "up{job=\"panthera\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "Runtime started",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 4, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "panthera_runtime_started{job=\"panthera\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "Startup errors",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "panthera_startup_errors{job=\"panthera\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Detector ready",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "panthera_detector_ready{job=\"panthera\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "title": "Detector errors",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "panthera_detector_has_error{job=\"panthera\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 6,
      "title": "VLM queued",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "panthera_vlm_calls_queued{job=\"panthera\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 7,
      "title": "HTTP request rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (path, status) (rate(panthera_http_requests_total{job=\"panthera\"}[5m]))",
          "legendFormat": "{{path}} {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops/s"
        }
      }
    },
    {
      "id": 8,
      "title": "HTTP p95 latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, path) (rate(panthera_http_request_duration_seconds_bucket{job=\"panthera\"}[5m])))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 9,
      "title": "Runtime and queue",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "panthera_camera_workers{job=\"panthera\"}",
          "legendFormat": "camera workers",
          "refId": "A"
        },
        {
          "expr": "panthera_vlm_calls_in_progress{job=\"panthera\"}",
          "legendFormat": "VLM in progress",
          "refId": "B"
        },
        {
          "expr": "panthera_vlm_calls_queued{job=\"panthera\"}",
          "legendFormat": "VLM queued",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 10,
      "title": "Camera decode and inference",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "panthera_camera_decode_milliseconds{job=\"panthera\",camera_id=~\"$camera_id\"}",
          "legendFormat": "{{camera_id}} decode",
          "refId": "A"
        },
        {
          "expr": "panthera_camera_inference_milliseconds{job=\"panthera\",camera_id=~\"$camera_id\"}",
          "legendFormat": "{{camera_id}} inference",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 11,
      "title": "Camera issues",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 40 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "panthera_camera_has_error{job=\"panthera\",camera_id=~\"$camera_id\"}",
          "legendFormat": "{{camera_id}} error",
          "refId": "A"
        },
        {
          "expr": "increase(panthera_camera_read_failures{job=\"panthera\",camera_id=~\"$camera_id\"}[15m])",
          "legendFormat": "{{camera_id}} read failures",
          "refId": "B"
        },
        {
          "expr": "increase(panthera_camera_reconnects{job=\"panthera\",camera_id=~\"$camera_id\"}[15m])",
          "legendFormat": "{{camera_id}} reconnects",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 12,
      "title": "Camera freshness",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 48 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "time() - panthera_camera_last_update_timestamp_seconds{job=\"panthera\",camera_id=~\"$camera_id\"}",
          "legendFormat": "{{camera_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 13,
      "title": "VLM activity",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 56 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "panthera_vlm_camera_in_progress{job=\"panthera\",camera_id=~\"$camera_id\"}",
          "legendFormat": "{{camera_id}} {{trigger_kind}}",
          "refId": "A"
        },
        {
          "expr": "panthera_vlm_video_analysis_in_progress{job=\"panthera\"}",
          "legendFormat": "video analysis in progress",
          "refId": "B"
        },
        {
          "expr": "panthera_vlm_video_analysis_queue_size{job=\"panthera\"}",
          "legendFormat": "video analysis queue",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    }
  ]
}
